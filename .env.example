# Fast Marketplace (commerce phase 1) — API server env

# ── Required ──────────────────────────────────────────────────────────────

# Postgres connection string. On Railway this is injected by the Postgres plugin.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/fast_marketplace

# Master key used to encrypt per-shop hint secrets at rest (aes-256-gcm).
# SHA-256'd internally so any length works; 32+ random bytes recommended.
# ⚠ PIN FOR LIFE. Rotating invalidates every stored ciphertext and forces
# re-seeding every shop through the admin API.
MARKETPLACE_SECRETS_KEY=replace-with-long-random-32+-byte-hex

# Bearer token for /admin/commerce/shops* endpoints. Rotate freely.
MARKETPLACE_ADMIN_TOKEN=replace-with-long-random-32+-byte-hex

# ── Optional ──────────────────────────────────────────────────────────────

# Public base URL (surfaced in /.well-known/marketplace.json). Defaults to
# http://localhost:${PORT} in dev.
# MARKETPLACE_BASE_URL=https://api.marketplace.fast.xyz

# CORS origin — set to a specific origin in prod, never '*'.
# CORS_ORIGIN=https://marketplace.fast.xyz

# Port to listen on. Railway injects this automatically.
# PORT=3000
