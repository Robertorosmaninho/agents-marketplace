{
  "name": "fast-agent-marketplace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && tsup --config tsup.config.ts",
    "test": "vitest run",
    "dev:api": "tsx apps/api/src/index.ts",
    "start:api": "node dist/apps/api/index.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
